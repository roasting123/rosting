rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // posts: anyone can read, signed-in can create, owner can edit/delete.
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['imageUrl', 'caption', 'userId', 'username', 'createdAt']);
      allow update, delete: if isOwner(resource.data.userId);

      // Per-user like state: existence = liked.
      match /likes/{userId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }

      // Roasts subcollection.
      match /roasts/{roastId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isOwner(resource.data.userId);

        // Per-user upvote state.
        match /upvoters/{userId} {
          allow read: if true;
          allow write: if isOwner(userId);
        }

        // Replies (1 level, text-only) on this roast.
        match /replies/{replyId} {
          allow read: if true;
          allow create: if isSignedIn()
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.keys().hasAll(['text', 'userId', 'username', 'userAvatarColor', 'createdAt']);
          allow update, delete: if isOwner(resource.data.userId);
        }
      }
    }

    // User profiles.
    match /users/{userId} {
      allow read: if true;
      // Owners can write their own profile, but `roastScoreTotal` is
      // server-managed (Cloud Function or one-time backfill) and cannot be
      // tampered with from the client.
      allow create, update: if isOwner(userId)
        && (!('roastScoreTotal' in request.resource.data)
            || request.resource.data.roastScoreTotal == resource.data.roastScoreTotal);
      allow delete: if false;

      // Mirror of liked post IDs (so we can quickly render "my likes" state).
      match /userLikes/{postId} {
        allow read, write: if isOwner(userId);
      }

      // In-app notifications for the bell dropdown.
      // Server (Cloud Functions) writes via Admin SDK bypass rules, but
      // we still allow the recipient to read + mark read + delete.
      match /notifications/{notifId} {
        allow read, update, delete: if isOwner(userId);
        // Writes from the client are disabled — only the Cloud Function
        // (using Admin SDK) creates these.
        allow create: if false;
      }
    }

    // Username claims. Doc ID = the lowercased username, so Firestore's
    // inherent doc-ID uniqueness IS the uniqueness constraint. Only the
    // owner of the claim may write; anyone can read (needed for the
    // search-by-prefix range scan).
    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && username.size() >= 3
        && username.size() <= 24
        && username.matches('^[a-z0-9_]+$');
      // Updates aren't expected — the workflow is create-or-replace.
      // Lock them down to the current owner for safety.
      allow update: if isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      // Only the claim owner may delete their own claim.
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }
  }
}
